<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.justinwilcott.litterbox-autopull</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/opt/homebrew/var/www/litterbox/scripts/auto-sync.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/opt/homebrew/var/www/litterbox</string>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>StandardOutPath</key>
    <string>/opt/homebrew/var/www/litterbox/autopull.log</string>

    <key>StandardErrorPath</key>
    <string>/opt/homebrew/var/www/litterbox/autopull.log</string>
</dict>
</plist>
